generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OfferStatus {
  DRAFT
  PRICED
  ACCEPTED
  DECLINED
}

enum OfferTemplate {
  TEMPLATE1
  TEMPLATE2
}

enum PitchStatus {
  DRAFT
  SENT
  ARCHIVED
}

model Offer {
  id            String      @id @default(cuid())
  slug          String      @unique
  status        OfferStatus @default(DRAFT)

  // Client
  clientName    String
  clientCompany String

  // Project
  projectName   String
  offerNumber   String?

  // Pulpmedia contact
  contactSlug   String
  contact       Contact     @relation(fields: [contactSlug], references: [slug])

  // Moco-Verknüpfung
  mocoRef           String?   // Lead-ID in Moco
  mocoCompanyId     String?   // Company-ID in Moco
  mocoCompanyName   String?   // Cache des Company-Namens
  mocoLeadStatus    String?   // Cache des Lead-Status zum Zeitpunkt der letzten Sync

  // Dates
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  validUntil    DateTime?
  archivedAt    DateTime?

  // Edit token for inline editor
  editToken     String      @unique @default(cuid())

  // === SECTIONS (JSON fields) ===
  hero          Json?       // { title, subtitle, headerImage }
  understanding Json?       // { headline, text, cards[] }
  services      Json?       // { headline, items[] }
  packages      Json?       // { intro, showPrices, items[] }
  notIncluded   Json?       // { hidden, headline, items[], note }
  timeline      Json?       // { headline, steps[] }
  stats         Json?       // [{ number, label, detail }]
  referenceIds  String[]    // IDs from Reference table
  channelIds    String[]    // IDs from Channel table
  channelsHidden   Boolean    @default(false)
  channelsHeadline String?    // Custom headline for channels section
  statsHeadline    String?    // Custom headline for stats section ("Warum Pulpmedia")
  referencesHeadline String?  // Custom headline for references section
  legal         Json?       // { paymentTerms }

  // Template
  template      OfferTemplate @default(TEMPLATE2)

  // Version tracking
  version       Int         @default(1)
  versions      OfferVersion[]

  @@index([status])
  @@index([contactSlug])
  @@index([archivedAt])
}

model OfferVersion {
  id        Int      @id @default(autoincrement())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  version   Int
  data      Json     // Full snapshot of the offer at this version
  changedBy String   // "paul", "robert", "editor", "skill"
  createdAt DateTime @default(now())

  @@index([offerId])
}

model Contact {
  slug      String   @id          // "paul", "robert", etc.
  name      String                // "Paul Lanzerstorfer"
  role      String                // "CEO"
  phone     String
  email     String
  avatarUrl String?
  offers    Offer[]
  pitches   Pitch[]
}

model Reference {
  id          String   @id @default(cuid())
  name        String                // "TGW Logistics"
  description String                // "Videoproduktion für TGW Logistics"
  url         String?               // "https://www.tgw-group.com" (Website-Link)
  imageUrl    String?
  tags        String[]              // ["Videoproduktion", "Industrie"]
  sortOrder   Int      @default(0)
}

model Channel {
  id        String   @id @default(cuid())
  name      String                // "efko Instagram", "Zipfer Facebook"
  platform  String   @default("") // "instagram", "facebook", "linkedin", etc. (auto-detected from URL)
  url       String                // "https://www.instagram.com/efkoat/"
  sortOrder Int      @default(0)
}

// ============================================================
// Pitches – Agenturpräsentationen pro Kunde
// ============================================================
//
// Eine Pitch-Seite ist eine modular zusammengestellte Agentur-
// präsentation, die nach dem Erstgespräch an den Kunden geschickt
// wird. Module sind global wiederverwendbar (Pulpies-Folie, Service-
// Detail, Stats, ...), werden aber beim Hinzufügen zum Pitch
// statisch reinkopiert (Snapshot), damit spätere Änderungen am
// globalen Modul die bestehende Pitch nicht "live" verändern.
// Per Button kann jederzeit auf die aktuelle Version aktualisiert
// werden.

model Pitch {
  id              String      @id @default(cuid())
  slug            String      @unique
  status          PitchStatus @default(DRAFT)

  // Kunde / Anlass
  clientCompany   String                  // "Fronius International GmbH"
  occasion        String?                 // "Erstgespräch", "Pitch", "Reminder", ...

  // Pulpmedia-Kontakt
  contactSlug     String
  contact         Contact     @relation(fields: [contactSlug], references: [slug])

  // Dates
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  archivedAt      DateTime?

  // Edit token (analog zum Offer)
  editToken       String      @unique @default(cuid())

  // Module-Snapshots: geordnete Liste aller in der Pitch verwendeten Module.
  // Struktur pro Eintrag: {
  //   instanceId: string,        // eindeutige ID innerhalb der Pitch
  //   moduleId: string | null,   // Referenz auf PitchModule.id (null = custom block)
  //   type: string,              // "hero", "team-grid", "service-detail", ...
  //   name: string,              // Anzeigename
  //   content: Json,             // Eingefrorener Inhalt zum Zeitpunkt des Hinzufügens
  //   sourceUpdatedAt: string,   // updatedAt des Quellmoduls bei Snapshot (für "Update verfügbar"-Check)
  //   sortOrder: number
  // }
  modules         Json        @default("[]")

  @@index([status])
  @@index([contactSlug])
  @@index([archivedAt])
}

model PitchModule {
  id          String   @id @default(cuid())
  type        String                // "hero", "manifest", "stats-grid", "team-grid",
                                    // "fun-facts", "services-grid", "service-detail",
                                    // "video", "image", "text", "outro"
  name        String                // sprechender Name, z.B. "Pulpies Standard", "Service: Hero Videos"
  description String?               // interne Notiz, was das Modul ist und wann man es nutzt
  content     Json                  // Typ-spezifischer Inhalt (Struktur variiert je nach type)
  createdBy   String                // Moco-Userslug oder Name
  sortOrder   Int      @default(0)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([archivedAt])
}

// ============================================================
// Tracking – Anonyme Nutzungsmessung für Offers (später Pitches)
// ============================================================
//
// Eine TrackView pro Browser pro Angebot (deduped über sessionId).
// Status-Snapshot beim Open, damit man später sieht, ob Zugriffe
// noch im DRAFT-Modus passierten oder schon im PRICED-Modus.
// Geo nur Country + Region (kein City, kein IP), Cookie-frei.

enum TrackTargetType {
  OFFER
  PITCH
}

model TrackView {
  id            String          @id @default(cuid())
  targetType    TrackTargetType
  targetId      String          // FK auf Offer.id oder Pitch.id (kein hard FK, generisch)
  targetSlug    String          // praktisch für Filter im Admin

  sessionId     String          // anonyme UUID aus dem Client (localStorage)
  openedAt      DateTime        @default(now())
  lastEventAt   DateTime        @default(now())
  activeSeconds Int             @default(0)

  // Status-Snapshot beim ersten Öffnen (z.B. "DRAFT", "PRICED", ...)
  targetStatus  String?

  // Kontext (Geo bewusst grob: kein City, kein IP)
  userAgent     String?
  referrer      String?
  country       String?         // 2-Letter ISO, aus Vercel Edge Header
  region        String?         // ISO 3166-2 Subdivision, aus Vercel Edge Header
  device        String?         // 'mobile' | 'tablet' | 'desktop'

  events        TrackEvent[]

  @@index([targetType, targetId])
  @@index([targetSlug])
  @@index([sessionId])
  @@index([openedAt])
}

model TrackEvent {
  id        String    @id @default(cuid())
  viewId    String
  view      TrackView @relation(fields: [viewId], references: [id], onDelete: Cascade)

  type      String    // "section_view", "link_click", "video_play", "video_progress", "heartbeat", "view_close"
  payload   Json?
  at        DateTime  @default(now())

  @@index([viewId])
  @@index([type])
  @@index([at])
}
