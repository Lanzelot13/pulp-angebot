generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OfferStatus {
  DRAFT
  PRICED
  ACCEPTED
}

enum OfferTemplate {
  TEMPLATE1
  TEMPLATE2
}

model Offer {
  id            String      @id @default(cuid())
  slug          String      @unique
  status        OfferStatus @default(DRAFT)

  // Client
  clientName    String
  clientCompany String

  // Project
  projectName   String
  offerNumber   String?

  // Pulpmedia contact
  contactSlug   String
  contact       Contact     @relation(fields: [contactSlug], references: [slug])

  // Optional Moco reference
  mocoRef       String?

  // Dates
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  validUntil    DateTime?
  archivedAt    DateTime?

  // Edit token for inline editor
  editToken     String      @unique @default(cuid())

  // === SECTIONS (JSON fields) ===
  hero          Json?       // { title, subtitle, headerImage }
  understanding Json?       // { headline, text, cards[] }
  services      Json?       // { headline, items[] }
  packages      Json?       // { intro, showPrices, items[] }
  notIncluded   Json?       // { hidden, headline, items[], note }
  timeline      Json?       // { headline, steps[] }
  stats         Json?       // [{ number, label, detail }]
  referenceIds  String[]    // IDs from Reference table
  channelIds    String[]    // IDs from Channel table
  channelsHidden   Boolean    @default(false)
  channelsHeadline String?    // Custom headline for channels section
  statsHeadline    String?    // Custom headline for stats section ("Warum Pulpmedia")
  referencesHeadline String?  // Custom headline for references section
  legal         Json?       // { paymentTerms }

  // Template
  template      OfferTemplate @default(TEMPLATE2)

  // Version tracking
  version       Int         @default(1)
  versions      OfferVersion[]

  @@index([status])
  @@index([contactSlug])
  @@index([archivedAt])
}

model OfferVersion {
  id        Int      @id @default(autoincrement())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  version   Int
  data      Json     // Full snapshot of the offer at this version
  changedBy String   // "paul", "robert", "editor", "skill"
  createdAt DateTime @default(now())

  @@index([offerId])
}

model Contact {
  slug      String   @id          // "paul", "robert", etc.
  name      String                // "Paul Lanzerstorfer"
  role      String                // "CEO"
  phone     String
  email     String
  avatarUrl String?
  offers    Offer[]
}

model Reference {
  id          String   @id @default(cuid())
  name        String                // "TGW Logistics"
  description String                // "Videoproduktion für TGW Logistics"
  url         String?               // "https://www.tgw-group.com" (Website-Link)
  imageUrl    String?
  tags        String[]              // ["Videoproduktion", "Industrie"]
  sortOrder   Int      @default(0)
}

model Channel {
  id        String   @id @default(cuid())
  name      String                // "efko Instagram", "Zipfer Facebook"
  platform  String   @default("") // "instagram", "facebook", "linkedin", etc. (auto-detected from URL)
  url       String                // "https://www.instagram.com/efkoat/"
  sortOrder Int      @default(0)
}
